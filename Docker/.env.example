# 复制本文件为 .env 后按需修改：cp .env.example .env
# 在项目根目录执行：docker compose -f Docker/docker-compose.yml up -d --build

# PostgreSQL（与 DATABASE_URL 一致）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bim_bidding

# 前端端口（浏览器访问入口）
FRONTEND_PORT=8080

# 前端构建时使用的 API 地址（浏览器访问后端的地址，一般本机即 localhost:8000）
VITE_API_BASE=http://localhost:8000

# 可选：大模型 API Key（也可在应用内「设置」页配置）
# DEEPSEEK_API_KEY=sk-...
# ZHIPU_API_KEY=...

# 可选：设置页加密密钥（32 字节 base64），不设则使用开发占位
# SETTINGS_SECRET_KEY=your-base64-32-bytes

# 可选：知识库（框架生成检索）
# KNOWLEDGE_BASE_TYPE=thinkdoc
# THINKDOC_API_URL=https://doc.bluedigit.ai
# THINKDOC_API_KEY=...
# THINKDOC_KB_IDS=...
