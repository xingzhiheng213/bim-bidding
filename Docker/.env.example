# 复制本文件为 .env 后按需修改：cp .env.example .env
# .env 勿提交到仓库（已由 .gitignore 排除）。生产环境请修改 POSTGRES_PASSWORD。
# 在 Docker 目录下执行：docker compose up -d --build
# 更多可选变量（LLM 超时、各步骤模型、章节长度等）见项目 backend/.env.example，按需复制到本 .env。

# PostgreSQL（与 DATABASE_URL 一致；生产环境请修改 POSTGRES_PASSWORD）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bim_bidding

# 前端端口（浏览器访问入口）
FRONTEND_PORT=8080

# 前端构建时使用的 API 地址（浏览器访问后端的地址，一般本机即 localhost:8001）
VITE_API_BASE=http://localhost:8001

# 可选：大模型 API Key（也可在应用内「设置」页配置，不写进 .env 更安全）
# DEEPSEEK_API_KEY=sk-...

# 可选：设置页加密密钥（32 字节 base64），不设则使用开发占位；应用内配置的 API Key 会加密存入 DB
# SETTINGS_SECRET_KEY=your-base64-32-bytes

# 可选：上传大小限制（MB），默认 50
# MAX_UPLOAD_SIZE_MB=50

# 可选：知识库（标书生成检索，不配置则不使用；可在应用内「设置」页配置）
# ThinkDoc（云）：
# KNOWLEDGE_BASE_TYPE=thinkdoc
# THINKDOC_API_URL=https://doc.bluedigit.ai
# THINKDOC_API_KEY=...
# THINKDOC_KB_IDS=...
# RAGFlow（自建）：需自行部署 RAGFlow，在「设置」页填 Base URL、API Key、Dataset IDs；
# 后端在 Docker 内时 Base URL 填 http://host.docker.internal:9380（Windows/Mac）或 RAGFlow 所在地址
# KNOWLEDGE_BASE_TYPE=ragflow
# RAGFLOW_API_URL=http://host.docker.internal:9380
# RAGFLOW_API_KEY=...
# RAGFLOW_DATASET_IDS=...
