# Redis (Celery broker and result backend)
# 无密码：redis://localhost:6379/0
# 有密码（口令里的 @ : # % 等需 URL 编码，例如 @ -> %40）：redis://:你的口令@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bim_bidding

# Upload: directory for uploaded files (relative to backend/ or absolute)
UPLOAD_DIR=data/uploads
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Copy this file to .env and fill in your values:
#   cp .env.example .env
