# Redis (Celery broker and result backend)
# 无密码：redis://localhost:6379/0
# 有密码（口令里的 @ : # % 等需 URL 编码，例如 @ -> %40）：redis://:你的口令@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bim_bidding

# Upload: directory for uploaded files (relative to backend/ or absolute)
UPLOAD_DIR=data/uploads
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=50

# [必填] 设置页 API Key 加密密钥（Fernet 32 字节 URL-safe base64）
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 未设置或格式无效时进程拒绝启动（SEC-02）
SETTINGS_SECRET_KEY=

# CORS：前端开发地址。默认还允许内网 IP + :5173（见 main.py 中 CORS_ALLOW_LAN_VITE）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 设为 0 可关闭内网 Vite 正则（仅保留 CORS_ORIGINS）
# CORS_ALLOW_LAN_VITE=1

# [生产环境建议必填] HTTP API 鉴权（SEC-01）：请求头 X-API-Key 须与此值一致；未设置则关闭鉴权（仅开发）
# 前端需在 .env.development / .env.production 中设置 VITE_API_KEY 为相同值
# ADMIN_API_KEY=

# Copy this file to .env and fill in your values:
#   cp .env.example .env
