# Redis (Celery broker and result backend)
# 无密码：redis://localhost:6379/0
# 有密码（口令里的 @ : # % 等需 URL 编码，例如 @ -> %40）：redis://:你的口令@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bim_bidding

# Upload: directory for uploaded files (relative to backend/ or absolute)
UPLOAD_DIR=data/uploads
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=50

# [必填] 设置页 API Key 加密密钥（Fernet 32字节 base64）
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 未设置时应用仍可启动，但会使用公开占位密钥加密，数据库泄露后 API Key 将直接暴露
SETTINGS_SECRET_KEY=

# Copy this file to .env and fill in your values:
#   cp .env.example .env
