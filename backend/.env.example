# Redis (Celery broker and result backend)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bim_bidding

# Upload: directory for uploaded files (relative to backend/ or absolute)
UPLOAD_DIR=data/uploads
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Export (stage 4.3): directory for generated DOCX, optional
# EXPORT_DIR=data/exports

# Settings (stage 5.1): Fernet key for encrypting API keys in DB (32 bytes base64). Optional: if unset, a fixed dev placeholder is used so FastAPI and Celery share the same key.
# SETTINGS_SECRET_KEY=your-base64-32-bytes

# LLM (stage 2.1+): at least one key for analysis/framework steps (or configure in App settings)
# DEEPSEEK_API_KEY=sk-...
# ZHIPU_API_KEY=...
# Optional: override base URLs
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# LLM HTTP timeout (seconds): read timeout for long analysis/framework (default 180)
# LLM_TIMEOUT_CONNECT=10
# LLM_TIMEOUT_READ=180

# Analyze step (stage 2.2): provider and model, default deepseek / deepseek-chat
# ANALYZE_LLM_PROVIDER=deepseek
# ANALYZE_LLM_MODEL=deepseek-chat

# Params step (stage 2.3): provider and model, default deepseek / deepseek-chat
# PARAMS_LLM_PROVIDER=deepseek
# PARAMS_LLM_MODEL=deepseek-chat

# Framework step (stage 2.4): provider and model, default deepseek / deepseek-chat
# FRAMEWORK_LLM_PROVIDER=deepseek
# FRAMEWORK_LLM_MODEL=deepseek-chat

# Chapter generation (stage 4.1): provider and model, default deepseek / deepseek-chat
# CHAPTER_LLM_PROVIDER=deepseek
# CHAPTER_LLM_MODEL=deepseek-chat

# Knowledge base (stage 2.4): thinkdoc | none; none = no retrieval, framework still runs
# KNOWLEDGE_BASE_TYPE=thinkdoc
# THINKDOC_API_URL=https://doc.bluedigit.ai
# THINKDOC_API_KEY=your-doc-api-key
# THINKDOC_KB_IDS=69725828f7f898efad71e93c

# Copy this file to .env and fill in your values:
#   cp .env.example .env
